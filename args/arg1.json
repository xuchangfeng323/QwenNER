{
    "num_epochs": 30,
    "batch_size": 64,
    "lr": 5e-5,
    "weight_decay": 0.01,
    "device": "cuda:0",
    "model_name": "Qwen2.5-0.5B",
    "model_dir": "model/Qwen2.5-0.5B",
    "dropout_rate": 0.2,
    "embedding_dim": 896,
    "data_path": "./data/",
    "max_length": 512,
    "max_new_tokens": 512,
    "patience":10,
    "monitor": "val_f1",
    "delta":0.0001,
    "save_dir": "./checkpoint",
    "warmup_steps": 5,
    "eps":1e-8,
    "lora_r": 8,
    "lora_alpha": 16,
    "lora_dropout": 0.1,
    "lora_target_modules": ["q_proj", "k_proj", "v_proj", "o_proj"]
}