{
    "num_epochs": 30,
    "batch_size": 64,
    "lr": 5e-5,
    "weight_decay": 0.01,
    "device": "cuda:0",
    "model_dir": "../bert-base-chinese",
    "dropout_rate": 0.2,
    "align_type": "other",
    "embedding_dim": 768,
    "data_path": "./data/",
    "max_length": 128,
    "patience":10,
    "monitor": "val_f1",
    "delta":0.0001,
    "save_dir": "./checkpoint",
    "warmup_steps": 5,
    "eps":1e-8
}